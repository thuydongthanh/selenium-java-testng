<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="OrangeHRm" verbose="1">

<!--DEMO Topic 04 TestNG-->
    <test name="Run on Chrome">
        <groups>
            <run>
                <!--Chạy tất cả Class KHÔNG có groupname là regressiton -->
                <exclude name="regression"/>
                <!--Chạy tất cả Class CÓ groupname là regressiton -->
                <include name="regression"/>
            </run>
        </groups>
        <!--chạy theo package-->
        <packages>
            <package name="payment"/>
            <package name="product"/>
            <package name="testng"/>
        </packages>

        <!--Chaỵ theo class -->
        <classes>
            <class name="testng.Topic_02_Annotation">
                <!--Chạy theo methods-->
                <methods>
                    <include name="TC_01"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>